{
  "manifest_version": 3,
  "name": "PixelFoxx",
  "version": "2.0.0",
  "description": "AI browser agent that navigates and automates tasks for you — pixelfoxx.io",
  "permissions": ["activeTab", "sidePanel", "tabs", "tabGroups", "debugger", "cookies"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "action": {
    "default_title": "Open PixelFoxx"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
