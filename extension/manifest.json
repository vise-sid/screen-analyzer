{
  "manifest_version": 3,
  "key": "",
  "name": "PixelFoxx",
  "version": "2.1.0",
  "description": "AI browser agent that navigates and automates tasks for you — pixelfoxx.io",
  "permissions": ["activeTab", "sidePanel", "tabs", "tabGroups", "debugger", "cookies", "identity", "storage"],
  "host_permissions": ["<all_urls>"],
  "oauth2": {
    "client_id": "412083714557-qpevl23i9prs3s2fngs90j6eaccb3rg5.apps.googleusercontent.com",
    "scopes": [
      "https://www.googleapis.com/auth/spreadsheets",
      "https://www.googleapis.com/auth/documents",
      "https://www.googleapis.com/auth/presentations",
      "https://www.googleapis.com/auth/drive.file"
    ]
  },
  "background": {
    "service_worker": "dist/background.js",
    "type": "classic"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "action": {
    "default_title": "Open PixelFoxx"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
